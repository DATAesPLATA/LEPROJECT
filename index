  }
  
  // Popup temporal
  const popup = document.createElement('div');
  popup.style.cssText = `
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    background:#1A1A1A;
    color:#FFD700;
    padding:30px 40px;
