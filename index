function renderSwiper(){
  const stack=$('card-stack'),empty=$('sw-empty'),btns=$('sw-btns');
  stack.innerHTML='';
  
  const pend=st.tarjetas.slice(st.swipeIdx);
  
  if(!pend.length){
    stack.style.display='none';
    empty.style.display='flex';
    btns.style.display='none';
    iniciarCountdown();
    return;
  }
  
  stack.style.display='block';
  empty.style.display='none';
  btns.style.display='flex';
  if(st.countdownInterval) clearInterval(st.countdownInterval);
  
  pend.slice(0,5).reverse().forEach((t,vi)=>{
    const div=document.createElement('div');
    div.className='swipe-card';
    div.id='sc-'+(t.id_tarjeta||t.id);
    div.dataset.tarjetaId = t.id_tarjeta||t.id;
    
    const imgBg = t.img_tarjeta || t.img || t.imagen || 'https://via.placeholder.com/300x600?text=Falta+Imagen';
    const logoSrc = t.logo_tarjeta || t.logo;
    const logoHtml = logoSrc ? `<div class="card-logo"><img src="${logoSrc}" alt="Logo"/></div>` : '';
    
// Textos - PRIORIZAR titulo/subtitulo si existen
    const cardName = t.titulo_tarjeta || t.nombre_marca || t.descripcion || 'Sin título';
    const cardBrand = t.subtitulo_tarjeta || t.detalle_categoria || t.nombre || 'Sin subtítulo';
    
// Detectar tipo de contenido
const esVideo = imgBg.match(/\.(mp4|webm|mov)$/i);
const bgHtml = esVideo 
  ? `<video class="card-bg" autoplay loop playsinline onplay="st.videoStartTime=Date.now()"><source src="${imgBg}" type="video/mp4"></video>`
  : `<div class="card-bg" style="background-image:url('${imgBg}')"></div>`;

    div.innerHTML=`
      ${bgHtml}
      ${logoHtml}
      <div class="card-info">
        <div class="card-name">${escH(cardName)}</div>
        <div class="card-brand">${escH(cardBrand)}</div>
      </div>
      <div class="ind ind-y">Me late ♥</div>
      <div class="ind ind-n">Paso ✕</div>
    `;
    
    const depth=Math.min(4,pend.length-1)-vi;
    div.style.zIndex=vi+1;
    if(depth>0) div.style.transform=`scale(${1-depth*.03}) translateY(${depth*5}px)`;
    
    attachDrag(div);
    stack.appendChild(div);
  });
}

function attachDrag(c){
  let sx=0,drag=false;
  const start=e=>{
    sx=(e.touches?e.touches[0].clientX:e.clientX);
    drag=true;
    c.style.transition='none';
  };
  const move=e=>{
    if(!drag)return;
    const dx=(e.touches?e.touches[0].clientX:e.clientX)-sx;
    
    if(dx > 0 && st.likesRestantes <= 0 && st.superRestantes <= 0) {
      return;
    }
    
    c.style.transform=`translateX(${dx}px) rotate(${dx*.06}deg)`;
    const iy=c.querySelector('.ind-y'),in_=c.querySelector('.ind-n');
    if(iy)iy.style.opacity=dx>28?Math.min((dx-28)/40,1):0;
    if(in_)in_.style.opacity=dx<-28?Math.min((-dx-28)/40,1):0;
    if(e.cancelable)e.preventDefault();
  };
  const end=e=>{
    if(!drag)return;drag=false;c.style.transition='';
    const dx=(e.changedTouches?e.changedTouches[0].clientX:e.clientX)-sx;
    c.querySelectorAll('.ind').forEach(i=>i.style.opacity=0);
    if(dx>60)swipeCard(true, false);else if(dx<-60)swipeCard(false, false);else c.style.transform='';
    document.removeEventListener('mousemove',move);
    document.removeEventListener('touchmove',move);
    document.removeEventListener('mouseup',end);
    document.removeEventListener('touchend',end);
  };
  c.addEventListener('mousedown',start);
  c.addEventListener('touchstart',start,{passive:true});
  document.addEventListener('mousemove',move);
  document.addEventListener('touchmove',move,{passive:false});
  document.addEventListener('mouseup',end);
  document.addEventListener('touchend',end);
}

async function swipeCard(esLike){
  if(st.swipeIdx >= st.tarjetas.length) return;
  
// DETECTOR DE SPEED-SWIPING
  const ahora = Date.now();
  st.swipeTimestamps.push(ahora);
  
  // Mantener solo los últimos 3 timestamps
  if(st.swipeTimestamps.length > 3) {
    st.swipeTimestamps.shift();
  }
  
  // Si hay 3 swipes en menos de 1.5 segundos
  if(st.swipeTimestamps.length === 3) {
    const diff = st.swipeTimestamps[2] - st.swipeTimestamps[0];
    if(diff < 1500) {
      registrarFaltaCliente('speed-swiping');
      st.swipeTimestamps = []; // Reset
      return; // Bloquear el swipe
    }
  }
  
  // DETECTOR DE ABANDONO DE VIDEO
  if(!verificarTiempoVideo()) {
  showToast('⚠️ Debes ver al menos 3s del video');
  return;
}

  const t = st.tarjetas[st.swipeIdx];
  const tarjetaId = t.id_tarjeta || t.id;
  
