function cambiarAvatar(){
  $('avatar-input').click();
}

function handleAvatarUpload(e){
  const file = e.target.files[0];
  if(!file) return;
  
  const reader = new FileReader();
  reader.onload = (ev) => {
    st.avatarUrl = ev.target.result;
    localStorage.setItem('dep_avatar_'+st.email, st.avatarUrl);
    renderProfile();
  };
  reader.readAsDataURL(file);
}

async function guardarPerfil(){
  const mascotas = Array.from(document.querySelectorAll('.pf-mascota:checked'))
    .map(cb => cb.value)
    .join(', ');
  
  const perfil = {
    nombre: $('pf-nombre').value.trim(),
    genero: $('pf-genero').value,
    fecha_nacimiento: $('pf-fecha').value,
    situacion_sentimental: $('pf-situacion').value,
    hijos: $('pf-hijos').value,
    mascotas: mascotas
  };
  
  loaderShow();
  
  try {
    const r = await apiPost({
      action: 'perfil',
      email: st.email,
      ...perfil
    });
    
    if(!r.ok) throw new Error(r.error);
    
    if(r.puntos_ganados > 0) {
      st.puntos = r.puntos_totales;
      updatePts();
      showToast(`¡+${r.puntos_ganados} puntos por completar tu perfil! 🎉`);
    } else {
      showToast('Perfil actualizado correctamente');
    }
    
    Object.assign(st.usuario, perfil);
    
  } catch(err) {
    showToast('Error: ' + err.message);
  }
  
  loaderHide();
}

function cerrarSesion(){
  // Limpiar estado
  st.usuario = null;
  st.email = null;
  st.sessionId = null;
  st.puntos = 0;
  st.tarjetas = [];
  st.recompensas = [];
  st.concursos = [];
  st.swipeIdx = 0;
  st.preferencias = null;
  st.avatarUrl = null;
  
  // Resetear nivel
  st.nivel = {
    actual: 'bronce',
    multiplicador: 1,
    exitos: 0,
    faltas: 0,
    feverActivo: false,
    feverSwipes: 0
  };
  
  // Limpiar countdown si existe
  if(st.countdownInterval) {
    clearInterval(st.countdownInterval);
    st.countdownInterval = null;
  }
  
  // CRÍTICO: ELIMINAR sessionId
  localStorage.removeItem('dep_session_id');
  localStorage.removeItem('dep_session_email');
  
  // Limpiar formularios
  if($('inp-password')) $('inp-password').value = '';
  if($('reg-password')) $('reg-password').value = '';
  
  // Volver a login
  showScreen('s-login');
  showToast('Sesión cerrada correctamente');
}  
