async function verificarYCrear() {
  const nombre = $('reg-nombre').value.trim();
  const email = $('reg-email').value.trim();
  const pass = $('reg-password').value;
  const codigo = [0,1,2,3,4,5].map(i=>$('otp'+i).value).join('');
  
  if(codigo.length<6) return showErr('otp-err','Introduce los 6 dígitos');
  
  $('btn-verificar').disabled = true;
  loaderShow();
  
  try {
    const r = await apiPost({
      action:'registro_otp',
      email,
      nombre,
      password:pass,
      otp:codigo,
      cookie_id:st.sessionId,
      userAgent:navigator.userAgent,
      geo:st.geo,
      pais:st.pais,
      latitud:st.latitud,
      longitud:st.longitud

    });
    
    if(!r.ok) throw new Error(r.error);
    
    localStorage.setItem('dep_saved_email', email);
    
    await procesarLoginExitoso(email, {nombre, puntos_disponibles:0});
  } catch(e) {
    showErr('otp-err', e.message);
  }
  
  $('btn-verificar').disabled = false;
  loaderHide();
}

function setupOTPInputs(){
  for(let i=0;i<6;i++){
    const inp=$('otp'+i);
    if(!inp)continue;
    inp.addEventListener('input',e=>{
      const v=e.target.value.replace(/\D/g,'');
      e.target.value=v.slice(-1);
      if(v&&i<5) $('otp'+(i+1)).focus();
      else if(v&&i===5) setTimeout(verificarYCrear, 200);
    });
    inp.addEventListener('keydown',e=>{
      if(e.key==='Backspace'&&!e.target.value&&i>0)$('otp'+(i-1)).focus();
    });
  }
}

async function procesarLoginExitoso(email, usuario) {
  st.email = email;
  st.usuario = usuario;
  st.sessionId = usuario.session_id;
  st.puntos = Number(usuario.puntos_disponibles||0);
  st.swipeIdx = 0;
  
  // Guardar session en localStorage
  if(st.sessionId) {
    localStorage.setItem('dep_session_id', st.sessionId);
    localStorage.setItem('dep_session_email', st.email);
  }
  
  // CARGAR NIVEL DEL USUARIO
  try {
    const rNivel = await apiPost({action:'get_nivel', email:email});
    if(rNivel.ok && rNivel.nivel) {
      st.nivel.actual = rNivel.nivel.nivel_actual || 'bronce';
      st.nivel.multiplicador = Number(rNivel.nivel.multiplicador_actual) || 1;
      st.nivel.exitos = Number(rNivel.nivel.exitos_acumulados) || 0;
      st.nivel.faltas = Number(rNivel.nivel.faltas_acumuladas) || 0;
      st.nivel.feverActivo = rNivel.nivel.fever_activo || false;
      st.nivel.feverSwipes = Number(rNivel.nivel.fever_swipes_restantes) || 0;
    }
  } catch(e) {
    console.error('Error cargando nivel:', e);
  }
  
  updatePts();
  showScreen('s-swiper');
  
  await cargarDatos();
  
  setTimeout(() => {
    actualizarUInivel();
    renderSwiper();
  }, 100);
}
