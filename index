async function init(){
  const savedEmail = localStorage.getItem('dep_saved_email');
  if(savedEmail) {
    $('inp-email').value = savedEmail;
    st.avatarUrl = localStorage.getItem('dep_avatar_'+savedEmail);
  }

  const sessionId = localStorage.getItem('dep_session_id');
  const savedSessionEmail = localStorage.getItem('dep_session_email');
  
  if(sessionId && savedSessionEmail){
    // Restaurar sesión directamente desde datos locales
    st.email = savedSessionEmail;
    st.sessionId = sessionId;
    
    try{
      const rUsuario = await api({action:'por_email', email:savedSessionEmail});
      if(rUsuario.ok && rUsuario.usuario) {
        st.usuario = rUsuario.usuario;
        st.puntos = Number(rUsuario.usuario.puntos_disponibles||0);
        st.swipeIdx = 0;
        
        // CARGAR NIVEL
        const rNivel = await apiPost({action:'get_nivel', email:savedSessionEmail});
        if(rNivel.ok && rNivel.nivel) {
          st.nivel.actual = rNivel.nivel.nivel_actual || 'bronce';
          st.nivel.multiplicador = Number(rNivel.nivel.multiplicador_actual) || 1;
          st.nivel.exitos = Number(rNivel.nivel.exitos_acumulados) || 0;
          st.nivel.faltas = Number(rNivel.nivel.faltas_acumuladas) || 0;
          st.nivel.feverActivo = rNivel.nivel.fever_activo || false;
          st.nivel.feverSwipes = Number(rNivel.nivel.fever_swipes_restantes) || 0;
        }
        
        updatePts();
        showScreen('s-swiper');
        
        await cargarDatos();
        
        setTimeout(() => {
          actualizarUInivel();
          renderSwiper();
        }, 100);
      }
    }catch(e){
      console.log('Error cargando datos de sesión:', e);
    }
  }
  
  loaderHide();
  setupOTPInputs();
  obtenerGeo();
}
  
