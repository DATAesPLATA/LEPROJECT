async function obtenerGeo(){
  try {
    const pos = await new Promise((resolve, reject) => {
      navigator.geolocation.getCurrentPosition(resolve, reject);
    });
    const {latitude, longitude} = pos.coords;
    st.latitud = latitude;    // ← NUEVO
    st.longitud = longitude;   // ← NUEVO
    
    const r = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latitude}&lon=${longitude}`);
    const data = await r.json();
    const ciudad = data.address.city || data.address.town || data.address.village || data.address.state || 'Ubicación';
    st.pais = data.address.country_code ? data.address.country_code.toUpperCase() : '';
    st.geo = `${ciudad}, ${st.pais}`;
    
    const geoEl = $('sw-geo');
    if(geoEl) geoEl.textContent = `📍 ${st.geo}`;
  } catch(e) {
    st.geo = 'Ubicación desconocida';
    st.pais = '';
    const geoEl = $('sw-geo');
    if(geoEl) geoEl.textContent = `📍 ${st.geo}`;
  }
}

