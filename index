    showToast('Error: Falta tarjeta_id');
    return;
  }
  
  const card = $('sc-'+tarjetaId);
  
  // Animación de swipe
  if(card) {
    card.classList.add(esLike ? 'liked' : 'gone');
  }
  
  st.swipeIdx++;
  
