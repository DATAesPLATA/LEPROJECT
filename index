function showScreen(id){
  ['s-login','s-swiper','s-promos','s-contests','s-profile'].forEach(s=>{
    const e=$(s);
    if(e)e.classList.remove('active');
  });
  const t=$(id);
  if(t)t.classList.add('active');
}

function goTab(t){
  showScreen('s-'+t);
  if(t==='promos') renderPromos();
  if(t==='contests') renderConcursos();
  if(t==='profile') renderProfile();
}

function goMain(){
  showScreen('s-swiper');
  updateProgressCircles();
}

function updatePts(){
  const p=st.puntos+' PTS';
  ['sw-pts','promo-pts','contest-pts','prof-pts'].forEach(id=>{
    const e=$(id);
    if(e)e.textContent=p;
  });
}

function showToast(msg){
  const t=$('toast');
  if(!t)return;
  t.textContent=msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),1900);
}

function loaderShow(){
  const l=$('loader');
  if(l){
    l.style.display='flex';
    l.classList.remove('hide');
  }
}

function loaderHide(){
  const l=$('loader');
  if(l){
    l.classList.add('hide');
    setTimeout(()=>l.style.display='none',350);
  }
}

function showErr(id,msg){
  const e=$(id);
  if(!e)return;
  e.textContent=msg;
  e.style.display=msg?'block':'none';
}

function escH(s){
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

