async function hacerLogin() {
  const email = $('inp-email').value.trim();
  const pass = $('inp-password').value;
  
  if(!email || !pass) return showErr('login-err', 'Ingresa correo y contraseña');
  
  $('btn-login').disabled = true;
  loaderShow();
  
  try {
    const r = await apiPost({
      action:'login_pass',
      email,
      password:pass,
      cookie_id:st.sessionId,
      userAgent:navigator.userAgent,
      geo:st.geo,
      pais:st.pais,
      latitud:st.latitud,
      longitud:st.longitud

      
    });
    
    if(!r.ok) throw new Error(r.error);
    
    localStorage.setItem('dep_saved_email', email);
    st.avatarUrl = localStorage.getItem('dep_avatar_'+email);
    
    await procesarLoginExitoso(email, r.usuario);
  } catch(e) {
    showErr('login-err', e.message);
  }
  
  $('btn-login').disabled = false;
  loaderHide();
}

