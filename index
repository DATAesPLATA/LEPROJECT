async function cargarDatos(){
  const email = st.email;
  
  const [rT, rR, rC, rCanjes] = await Promise.all([
    api({action:'tarjetas', email}),
    api({action:'recompensas', email}),
    api({action:'concursos', email}),
    api({action:'canjes_usuario', email}) // ← NUEVO
  ]);
  
  st.tarjetas = rT.tarjetas || [];
  st.recompensas = rR.recompensas || [];
  st.concursos = rC.concursos || [];
  st.canjesRealizados = rCanjes.canjes || []; // ← NUEVO
}
  
