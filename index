      nombre_categoria: t.nombre_categoria || '',
      detalle_categoria: t.detalle_categoria || '',
      geo: st.geo,
      pais: st.pais,
      latitud: st.latitud,
      longitud: st.longitud
    });
    
    if(!r.ok) {
      throw new Error(r.error || 'Error desconocido');
    }
    
    // Actualizar puntos
    st.puntos += r.puntos_ganados;
    updatePts();
    
    // Actualizar nivel
    if(r.nivel_actual) {
      st.nivel.actual = r.nivel_actual;
      st.nivel.multiplicador = r.multiplicador || 1;
      actualizarUInivel();
    }
    
    // Actualizar badge de multiplicador
    const multiBadge = $('multi-badge');
    if(multiBadge) {
      multiBadge.textContent = 'x' + (r.multiplicador || 1);
    }
    
    // Mostrar puntos ganados
    const emoji = r.es_fever ? '👹' : '🫘';
    showToast(`+${r.puntos_ganados} punto${r.puntos_ganados>1?'s':''} ${emoji}`);
    
    // Si activó FEVER, mostrar alerta
    if(r.es_fever && !st.nivel.feverActivo) {
      st.nivel.feverActivo = true;
      st.nivel.feverSwipes = 10;
      mostrarFeverActivado();
    }
    
  } catch(err) {
    showToast('Error: ' + err.message);
    if(card) {
      card.classList.remove('liked', 'gone');
      card.style.transform = '';
    }
    st.swipeIdx--;
    return;
  }
  
  setTimeout(renderSwiper, 300);
}
  
function verificarTiempoVideo(){
  if(!st.videoStartTime) return true; // No es video
  
  const tiempoVisto = (Date.now() - st.videoStartTime) / 1000; // segundos
  
  if(tiempoVisto < 3) {
    registrarFaltaCliente('abandono-video');
    st.videoStartTime = null;
    return false; // Bloquear swipe
  }
  
  st.videoStartTime = null;
  return true; // OK
}
  async function registrarFaltaCliente(tipoFalta){
  showToast('⚠️ Falta detectada: ' + tipoFalta);
  
  try {
    const r = await apiPost({
      action: 'registrar_falta',
      email: st.email,
      tipo_falta: tipoFalta
    });
    
    if(r.ok) {
      st.nivel.faltas = r.faltas_actuales || 0;
      
      // Si bajó de nivel
      if(r.bajo) {
        st.nivel.actual = r.nivel_nuevo;
        st.nivel.multiplicador = r.multiplicador_nuevo || 1;
        actualizarUInivel();
        
        mostrarAlertaBajada(r.nivel_anterior, r.nivel_nuevo);
      } else {
        actualizarUInivel();
      }
    }
  } catch(e) {
    console.error('Error registrando falta:', e);
  }
}
