let pendingCanje={};

function tryUnlock(tipo, id, pts){
  pendingCanje = {tipo, id, pts};
  const modal = $('conf-modal');
  const msg = $('conf-msg');
  if(!modal || !msg) return;
  
  msg.innerHTML = `<div style="margin-top:10px;font-size:14px;font-weight:bold;color:#C0157A">${pts} puntos</div>`;
  modal.style.display='flex';
}

async function executeCanje(){
  $('conf-modal').style.display='none';
  loaderShow();
  
  try {
    const r = await apiPost({
      action:'canje',
      email:st.email,
      session_id:st.sessionId,
      tipo:pendingCanje.tipo,
      id_item:pendingCanje.id,
      puntos_requeridos:pendingCanje.pts,
      geo:st.geo,
      pais:st.pais,
      latitud:st.latitud,
      longitud:st.longitud
    });
    
    if(!r.ok) throw new Error(r.error);
    
    st.puntos = r.puntos_restantes;
    updatePts();
    
    // ← NUEVO: AÑADIR EL CANJE A LA LISTA LOCAL
    st.canjesRealizados.push({
      id_item: pendingCanje.id,
      codigo_canje: r.codigo_canje,
      tipo: pendingCanje.tipo
    });
    
    // MOSTRAR MODAL CON CONFETTI
    const modal = $('umodal');
    const ico = $('u-ico');
    const title = $('u-title');
    const sub = $('u-sub');
    const code = $('u-code');
    
    ico.textContent = '🎁';
    title.textContent = 'Canje exitoso';
    sub.textContent = 'Presenta este código en el establecimiento';
    code.textContent = r.codigo_canje; // ← QUITAR .replace('CANJE-','') porque ahora es Data$-XX11
    
    modal.style.display='flex';
    startConf();
    
    // ← NUEVO: RE-RENDERIZAR INMEDIATAMENTE
    if(pendingCanje.tipo === 'recompensa') renderPromos();
    else renderConcursos();
    
  } catch(err) {
    showToast('Error: ' + err.message);
  }
  
  loaderHide();
}
  
  function verDetalleCanje(idItem){
  const canje = st.canjesRealizados.find(c => c.id_item === idItem);
  if(!canje) return;
  
  const modal = $('umodal');
  const ico = $('u-ico');
  const title = $('u-title');
  const sub = $('u-sub');
  const code = $('u-code');
  
  ico.textContent = '🎁';
  title.textContent = 'Tu código de canje';
  sub.textContent = 'Presenta este código en el establecimiento';
  code.textContent = canje.codigo_canje;
  
  modal.style.display='flex';
}
  
let confInterval;
function startConf(){
  const cvs=$('conf-cvs');
  if(!cvs)return;
  const ctx=cvs.getContext('2d');
  cvs.width=window.innerWidth;
  cvs.height=window.innerHeight;
  const pieces=[];
  for(let i=0;i<60;i++){
    pieces.push({
      x:Math.random()*cvs.width,
      y:-20,
      r:Math.random()*4+2,
      dx:Math.random()*2-1,
      dy:Math.random()*3+2,
      c:['#C0157A','#FFD700','#4CAF50','#FF5722'][Math.floor(Math.random()*4)]
    });
  }
  confInterval=setInterval(()=>{
    ctx.clearRect(0,0,cvs.width,cvs.height);
    pieces.forEach(p=>{
      p.x+=p.dx;p.y+=p.dy;
      ctx.fillStyle=p.c;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();
      if(p.y>cvs.height){p.y=-20;p.x=Math.random()*cvs.width;}
    });
  },30);
}

function stopConf(){
  if(confInterval){clearInterval(confInterval);confInterval=null;}
  const cvs=$('conf-cvs');
  if(cvs){const ctx=cvs.getContext('2d');ctx.clearRect(0,0,cvs.width,cvs.height);}
}

