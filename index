    'oro': '🥇',
    'diamante': '💎',
    'fever': '👹'
  };
  
  // Labels de progreso
  const labels = {
    'bronce': 'BRONCE → PLATA',
    'plata': 'PLATA → ORO',
    'oro': 'ORO → DIAMANTE',
    'diamante': 'DIAMANTE',
    'fever': 'FEVER MODE'
  };
  
  // Límites para subir
  const limitesExito = {
    'bronce': 5,
    'plata': 5,
    'oro': 1, // Éxito especial
    'diamante': 0
  };
  
  // Límites de faltas
  const limitesFalta = {
    'bronce': 0,
    'plata': 3,
    'oro': 3,
    'diamante': 1
  };
  
  const nivelActual = st.nivel.feverActivo ? 'fever' : st.nivel.actual;
  
  emojiEl.textContent = emojis[nivelActual] || '🥉';
  labelEl.textContent = labels[nivelActual] || 'NIVEL';
  
  const exitosLimite = limitesExito[st.nivel.actual] || 5;
  const faltasLimite = limitesFalta[st.nivel.actual] || 3;
  
  statsEl.textContent = `✓ ${st.nivel.exitos}/${exitosLimite} | ⚠️ ${st.nivel.faltas}/${faltasLimite}`;
  
  // Barra de progreso (basada en éxitos)
  const progreso = exitosLimite > 0 ? (st.nivel.exitos / exitosLimite) * 100 : 0;
  barEl.style.width = Math.min(progreso, 100) + '%';
  
  // Si está en FEVER, barra dorada y pulsante
  if(st.nivel.feverActivo) {
    barEl.style.background = 'linear-gradient(90deg, #FFD700, #FFA500)';
    barEl.style.animation = 'pulse-fever 0.5s infinite';
  } else {
    barEl.style.background = 'linear-gradient(90deg, #C0157A, #FF1493)';
    barEl.style.animation = 'none';
  }
}

